generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                  @id @default(cuid())
  name                    String
  email                   String                  @unique
  mobile                  String                  @unique
  password                String
  createdAt               DateTime                @default(now())
  resetOtp                String?
  resetOtpExpiry          DateTime?

  profile                 UserProfile?

  josaaAllocations        JosaaAllocation[]
  csabAllocations         CsabAllocation[]

  recommendationHistories RecommendationHistory[]
}

model UserProfile {
  id          String   @id @default(cuid())

  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])

  category    String?
  gender      String?
  pwd         String?
  homeState   String?

  jeeMains    Int?
  jeeAdvanced Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model JosaaAllocation {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  round     Int
  college   String
  branch    String
  status    String

  createdAt DateTime @default(now())
}

model CsabAllocation {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  round     Int
  college   String
  branch    String
  status    String

  createdAt DateTime @default(now())
}

model PendingSignup {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  mobile    String   @unique
  password  String
  isPremium Boolean  @default(false)
  resetOtp       String?
  resetOtpExpiry DateTime?
  createdAt DateTime @default(now())
  recommendationHistories RecommendationHistory[]
  payments                Payment[]
}

model Payment {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  razorpayOrderId    String   @unique
  razorpayPaymentId  String?

  amount             Int
  currency           String   @default("INR")
  plan               String
  status             String   @default("PENDING")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  otp       String
  otpExpiry DateTime
  createdAt DateTime @default(now())
}

model SeatRecord {
  id          String   @id @default(cuid())
  institute   String
  program     String
  quota       String
  seatType    String
  gender      String
  year        Int
  openingRank Int
  closingRank Int
  round       Int
  isPwd       String
  createdAt   DateTime @default(now())
  @@unique([institute, program, quota, seatType, gender, year, round, isPwd])
}

model CollegeFee {
  id               String @id @default(cuid())
  collegeName      String
  collegeShortName String @unique
  fees             Int
  instType         String
}

model CutoffPrediction {
  id                       String   @id
  institute                String
  branchShortcut           String
  degreeType               String?
  quota                    String?
  seatType                 String?
  gender                   String?
  collegeState             String?
  predictedClosingRank2026 Int
  instituteType            String?
  globalPrestigeIndex      Float?
  globalBranchPopularity   Float?
  createdAt                DateTime @default(now())
}

model PreferenceProfile {
  id String @id @default(cuid())
  mainCategoryRank Int
  advCategoryRank Int?
  category String
  homeState String
  gender String
  hometownWeight Int
  collegeWeight Int
  branchWeight Int
  preferredBranches Json
  createdAt DateTime @default(now())
  generatedLists GeneratedList[]
  histories RecommendationHistory[]
}

model GeneratedList {
  id String @id @default(cuid())
  profileId String
  generatedResults Json
  totalResults Int
  createdAt DateTime @default(now())
  profile PreferenceProfile @relation(fields: [profileId], references: [id])
  histories RecommendationHistory[]
}

model RecommendationHistory {
  id String @id @default(cuid())
  userId String?
  profileId String?
  generatedListId String
  pdfUrl String?
  createdAt DateTime @default(now())
  user User? @relation(fields: [userId], references: [id])
  profile PreferenceProfile? @relation(fields: [profileId], references: [id])
  generatedList GeneratedList @relation(fields: [generatedListId], references: [id])
}
  id                String                  @id @default(cuid())
  category          String
  homeState         String
  gender            String
  hometownWeight    Int
  collegeWeight     Int
  branchWeight      Int
  createdAt         DateTime                @default(now())
  advCategoryRank   Int?
  mainCategoryRank  Int
  preferredBranches Json
  generatedLists    GeneratedList[]
  histories         RecommendationHistory[]
}

model GeneratedList {
  id               String                  @id @default(cuid())
  profileId        String
  createdAt        DateTime                @default(now())
  generatedResults Json
  totalResults     Int
  profile          PreferenceProfile       @relation(fields: [profileId], references: [id])
  histories        RecommendationHistory[]
}

model RecommendationHistory {
  id              String             @id @default(cuid())
  userId          String?
  profileId       String?
  pdfUrl          String?
  createdAt       DateTime           @default(now())
  generatedListId String
  generatedList   GeneratedList      @relation(fields: [generatedListId], references: [id])
  profile         PreferenceProfile? @relation(fields: [profileId], references: [id])
  user            User?              @relation(fields: [userId], references: [id])
}
