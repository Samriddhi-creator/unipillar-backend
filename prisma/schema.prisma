generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  mobile    String   @unique
  password  String

  resetOtp       String?
  resetOtpExpiry DateTime?

  createdAt DateTime @default(now())

  recommendationHistories RecommendationHistory[]
}

model SeatRecord {
  id          String   @id @default(cuid())
  institute   String
  program     String
  quota       String
  seatType    String
  gender      String
  year        Int
  openingRank Int
  closingRank Int
  round       Int
  isPwd       String
  createdAt   DateTime @default(now())

  @@unique([institute, program, quota, seatType, gender, year, round, isPwd])
}

model CollegeFee {
  id               String @id @default(cuid())
  collegeName      String
  collegeShortName String @unique
  fees             Int
  instType         String
}

model CutoffPrediction {
  id                       String   @id
  institute                String
  branchShortcut           String
  degreeType               String?
  quota                    String?
  seatType                 String?
  gender                   String?
  collegeState             String?
  predictedClosingRank2026 Int
  instituteType            String?
  globalPrestigeIndex      Float?
  globalBranchPopularity   Float?
  createdAt                DateTime @default(now())
}

model PreferenceProfile {
  id String @id @default(cuid())

  mainCategoryRank Int

  advCategoryRank Int?

  category String

  homeState String

  gender String

  hometownWeight Int

  collegeWeight Int

  branchWeight Int

  preferredBranches Json

  createdAt DateTime @default(now())

  generatedLists GeneratedList[]

  histories RecommendationHistory[]
}

model GeneratedList {
  id String @id @default(cuid())

  profileId String

  generatedResults Json

  totalResults Int

  createdAt DateTime @default(now())

  profile PreferenceProfile @relation(fields: [profileId], references: [id])

  histories RecommendationHistory[]
}

model RecommendationHistory {
  id String @id @default(cuid())

  userId String?

  profileId String?

  generatedListId String

  pdfUrl String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  profile PreferenceProfile? @relation(fields: [profileId], references: [id])

  generatedList GeneratedList @relation(fields: [generatedListId], references: [id])
}
